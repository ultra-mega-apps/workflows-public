#!/usr/bin/env zsh
set -euo pipefail

WORKFLOWS_DIR=".github/workflows"
CAPROVER_WORKFLOW="${WORKFLOWS_DIR}/caprover-deployment-caller.yaml"
MANUAL_WORKFLOW="${WORKFLOWS_DIR}/manual-caprover-deployment.yaml"
SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
TEMPLATE_WORKFLOWS_DIR="${SCRIPT_DIR}/.github/workflows"
CAPROVER_TEMPLATE="${TEMPLATE_WORKFLOWS_DIR}/caprover-deployment-caller.yaml"
MANUAL_TEMPLATE="${TEMPLATE_WORKFLOWS_DIR}/manual-caprover-deployment.yaml"

if [[ ! -d ".git" ]]; then
	echo "Error: run this script from the root of a git repository." >&2
	exit 1
fi

REPO_NAME=$(basename "$PWD")

echo "Setting up GitHub Actions workflows for: ${REPO_NAME}"
echo "Target directory: ${PWD}/${WORKFLOWS_DIR}"
echo "Template directory: ${TEMPLATE_WORKFLOWS_DIR}"

if [[ ! -f "${CAPROVER_TEMPLATE}" ]]; then
	echo "Error: missing template file ${CAPROVER_TEMPLATE}" >&2
	exit 1
fi

if [[ ! -f "${MANUAL_TEMPLATE}" ]]; then
	echo "Error: missing template file ${MANUAL_TEMPLATE}" >&2
	exit 1
fi

mkdir -p "${WORKFLOWS_DIR}"

copy_template_file() {
	local source_path="$1"
	local target_path="$2"

	if [[ "${source_path:A}" == "${target_path:A}" ]]; then
		echo "Skipping ${target_path} (source and target are the same file)"
		return
	fi

	# if [[ -f "${target_path}" ]]; then
	# 	echo "Skipping ${target_path} (already exists)"
	# 	return
	# fi

	cp "${source_path}" "${target_path}"
	echo "Created ${target_path}"
}

copy_template_file "${CAPROVER_TEMPLATE}" "${CAPROVER_WORKFLOW}"
copy_template_file "${MANUAL_TEMPLATE}" "${MANUAL_WORKFLOW}"

echo "Done. Review the generated files and adjust branch/server options as needed."
